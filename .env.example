OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=translategemma:12b
APP_PORT=8000
APP_HOST=127.0.0.1
MAX_INPUT_CHARS=5000

# --- Phase 2: OCR ---

# Full path to tesseract binary. Leave blank if tesseract is on your PATH.
# Example: /usr/local/bin/tesseract
TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Maximum allowed upload size in bytes (default: 15 MB)
MAX_IMAGE_BYTES=15000000

# Image preprocessing — set to "true" or "false"
OCR_AUTO_RESIZE=true
OCR_MAX_DIMENSION=3000
OCR_AUTO_ENHANCE=true

# OCR confidence thresholds for color-coded indicator (0–100)
# >= CONF_HIGH   → green   ("Good")
# >= CONF_MEDIUM → yellow  ("Fair")
# >= CONF_LOW    → orange  ("Poor")
# <  CONF_LOW    → red     ("Low — review carefully")
OCR_CONF_HIGH=95
OCR_CONF_MEDIUM=90
OCR_CONF_LOW=85
